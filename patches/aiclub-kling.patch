+// flexibleCode supports JSON unmarshalling from both numeric and string codes.
+// AIClub returns code as number 200 for submit and string "200" for query.
+type flexibleCode int
+
+func (fc *flexibleCode) UnmarshalJSON(data []byte) error {
+	s := strings.TrimSpace(string(data))
+	if s == "null" || s == "" {
+		return nil
+	}
+	// Remove surrounding quotes if present (JSON string value)
+	if len(s) >= 2 && s[0] == '"' && s[len(s)-1] == '"' {
+		s = s[1 : len(s)-1]
+	}
+	var n int
+	if _, err := fmt.Sscanf(s, "%d", &n); err != nil {
+		return fmt.Errorf("cannot parse %q as flexibleCode", s)
+	}
+	*fc = flexibleCode(n)
+	return nil
+}
+
+func (fc flexibleCode) Int() int {
+	return int(fc)
+}
